# Copy this file to .env (never commit .env itself — it's gitignored)
# and fill in real values. Used by voicelab/mailer.py to send the
# teapunk installation's finished manifesto recordings by email.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=solarpunk@udk.ai
SMTP_PASSWORD=changeme
# Optional, defaults to solarpunk@udk.ai if omitted:
SMTP_FROM=solarpunk@udk.ai
